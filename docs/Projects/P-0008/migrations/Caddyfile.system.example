# /etc/caddy/Caddyfile  (operator-managed, NOT generated by Latarnia)
#
# This is the system Caddyfile installed once on the Pi. It only imports the
# per-environment include files that each Latarnia environment generates and
# maintains via CaddyConfigManager. Latarnia never writes THIS file — it
# writes the included files and then runs `caddy reload --config
# /etc/caddy/Caddyfile` so all imported sections are re-read together.
#
# Global options: bind the admin API to localhost only (default, stated
# explicitly here for clarity / auditability).
{
    admin localhost:2019
}

# Import each environment's generated include. A missing file is tolerated
# (the env may not be deployed yet) — Caddy's `import` of a non-existent glob
# is a no-op when written as a glob; list explicit paths only for envs that
# exist on this host.
import /opt/latarnia/prd/caddy/latarnia.caddyfile
import /opt/latarnia/tst/caddy/latarnia.caddyfile

# Install steps (Debian, official repo — NOT snap):
#   sudo apt install -y debian-keyring debian-archive-keyring apt-transport-https curl
#   curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' \
#     | sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
#   curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' \
#     | sudo tee /etc/apt/sources.list.d/caddy-stable.list
#   sudo apt update && sudo apt install -y caddy
#   sudo systemctl enable --now caddy
#
# After editing this file: sudo systemctl reload caddy
