# Latarnia environment configuration — copy to `.env` and adjust.
# `.env` is gitignored; this example is committed.

# Environment selector (dev | tst | prd). Default: dev
ENV=dev

# --- Public domain per environment (P-0008 / Caddy) -------------------------
# CaddyConfigManager reads {ENV}_DOMAIN to build the Caddy site address:
#   prd -> {PRD_DOMAIN}:443     tst -> {TST_DOMAIN}:8443
# When unset (or `localhost`), Caddy serves its automatic self-signed cert
# (dev). A real hostname triggers Let's Encrypt provisioning via ACME HTTP-01
# (port 80 must be reachable). PRD and TST may point at the same domain.
DEV_DOMAIN=localhost
TST_DOMAIN=home.stanham.com
PRD_DOMAIN=home.stanham.com

# --- Dev environment --------------------------------------------------------
DEV_REDIS_HOST=localhost
DEV_REDIS_PORT=6379
DEV_MAIN_PORT=8000

# --- Prod environment -------------------------------------------------------
PROD_REDIS_HOST=localhost
PROD_REDIS_PORT=6379
PROD_MAIN_PORT=8000

# --- Platform auth secrets (P-0008) -----------------------------------------
# These live in the per-env master secrets file (secrets.env, mode 600), NOT
# in .env. Listed here only so operators know they are required:
#   LATARNIA_TOTP_ENC_KEY  — 32-byte base64 AES key for TOTP secret encryption
#   LATARNIA_JWT_SECRET    — HMAC secret for signing machine-token JWTs
# Generate:
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
