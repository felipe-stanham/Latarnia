{
  "redis": {
    "host": "localhost",
    "port": 6379,
    "db": 0
  },
  "postgres": {
    "host": "localhost",
    "port": 5432,
    "superuser": "",
    "superuser_password": "",
    "database_prefix": "latarnia_",
    "role_prefix": "latarnia_"
  },
  "event_subscriber": {
    "max_events": 100,
    "channels": ["latarnia:events:*"]
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(levelname)s - [%(name)s] - %(message)s"
  },
  "process_manager": {
    "data_dir": "data",
    "logs_dir": "logs",
    "streamlit_port": 8501,
    "streamlit_ttl_seconds": 300,
    "port_range": {
      "start": 8100,
      "end": 8199
    },
    "mcp_port_range": {
      "start": 9001,
      "end": 9099
    }
  },
  "health_check_interval_seconds": 60,
  "system": {
    "main_port": 8000,
    "host": "0.0.0.0"
  },
  "mcp": {
    "enabled": true,
    "transport": "sse",
    "gateway_path": "/mcp",
    "tool_sync_interval_seconds": 300
  }
}
